# --- PostgreSQL ---
POSTGRES_DB=resume_analyzer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Redis ---
# (no auth by default for local dev)

# --- Backend ---
JWT_SECRET=change-this-super-secret-key-min-256-bits-long-for-hs256-signing
JWT_EXPIRATION_MS=86400000
CORS_ALLOWED_ORIGINS=http://localhost:3000
DAILY_ANALYSIS_LIMIT=5
# --- AI Provider ---
# Choose one: anthropic | gemini | groq | ollama
AI_PROVIDER=anthropic
AI_TIMEOUT_MS=60000

# Anthropic Claude (paid, requires credit balance)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages

# Google Gemini (free tier available - https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models

# Groq (free tier with generous rate limits - https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1/chat/completions

# Ollama (local, no API key needed - https://ollama.com)
# When running via Docker, the backend reaches your host machine's Ollama at host.docker.internal
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
